# IDE / tooling
.idea/
.vscode/
.claude/

# OS
.DS_Store
Thumbs.db

# Local Docker overrides
.env

# Snapshots — generowane lokalnie przy pierwszym docker compose up
snapshots/*
!snapshots/.gitkeep

# WordPress runtime — wszystko siedzi w named volume, nie commitujemy
wordpress/

# wp-content jest bind-mountowany do kontenera, traktujemy jako runtime
wp-content/
